{
  "compilerOptions": {
    "moduleResolution": "node",
    "types": ["node"],
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "server/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
