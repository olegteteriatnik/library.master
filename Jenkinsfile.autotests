pipeline {
  agent any

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Build autotests Docker Image') {
      steps {
        sh 'docker build -f Dockerfile.autotests -t library.master-e2e .'
      }
    }

    stage('Run tests') {
      steps {
        sh 'docker run --rm -e CI=true library.master-e2e'
      }
    }
  }

  post {
    success {
      echo '✅ E2E tests passed!'
    }
    failure {
      echo '❌ E2E tests failed.'
    }
  }
}
